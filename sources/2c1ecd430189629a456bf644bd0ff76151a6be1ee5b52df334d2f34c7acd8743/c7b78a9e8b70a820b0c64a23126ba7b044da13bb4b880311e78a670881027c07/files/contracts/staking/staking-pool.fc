#include "../imports/stdlib.fc";
#include "../imports/messages.fc";
#include "../imports/params.fc";
#include "../jetton/jetton-utils.fc";
#include "../imports/utils.fc";
#include "error-codes.fc";
#include "op-codes.fc";

const int min_tons_for_storage = 20000000;
const int account_create_amount = 10000000;

const int op::jetton_transfer = 0xf8a7ea5;
const int op::jetton_transfer_notification = 0x7362d09c;

;; Staking pool smart contract

(slice, cell, slice, int, int) load_data() inline {
    var ds = get_data().begin_parse();
    var (owner, staking_acount_code) =
        (ds~load_msg_addr(), ds~load_ref());

    if (ds.slice_bits() > 0) {
        return (
            owner,
            staking_acount_code,
            ds~load_msg_addr(), ;; jetton_wallet
            ds~load_uint(64), ;; staking_period
            ds~load_coins() ;; min_staking_amount
        );
    } else {
        return (owner, staking_acount_code, null(), 0, 0);
    }        
}

() save_data(slice owner, cell staking_acount_code, slice jetton_wallet, int staking_period, int min_staking_amount) impure inline {
    set_data(
        begin_cell()
            .store_slice(owner)
            .store_ref(staking_acount_code)
            .store_slice(jetton_wallet)
            .store_uint(staking_period, 64)
            .store_coins(min_staking_amount)
        .end_cell()
    );
}

cell pack_staking_acount_data(slice staking_pool, slice user_address) inline {
    return begin_cell()
                .store_slice(staking_pool)
                .store_slice(user_address)
           .end_cell();
}
{-
    _ split_depth:(Maybe (## 5)) special:(Maybe TickTock)
      code:(Maybe ^Cell) data:(Maybe ^Cell)
      library:(HashmapE 256 SimpleLib) = StateInit;
-}
cell calculate_account_state_init(slice staking_pool, slice user_address, cell code) inline {
    return  begin_cell()
                .store_uint(0,1 + 1) ;; split_depth (Maybe = 0) and special (Maybe = 0)
                .store_maybe_ref(code)
                .store_maybe_ref(pack_staking_acount_data(staking_pool, user_address))
                .store_uint(0,1) ;; libraries - empty cell
            .end_cell();
}

() send_on_supply(slice user_address, cell acount_code, int amount, int end_date, int query_id) impure {
    cell state_init = calculate_account_state_init(my_address(), user_address, acount_code);
    slice account_address = calc_address(state_init);
    var msg = begin_cell()
            .store_msg_flag(msg_flag::bounceable)
            .store_slice(account_address)
            .store_coins(0)
            .store_msgbody_prefix_stateinit(
                state_init,
                begin_cell()
                    .store_op(op::on_supply)
                    .store_query_id(query_id) 
                    .store_coins(amount)
                    .store_int(end_date, 64)
                .end_cell()
            );
    send_raw_message(msg.end_cell(), CARRY_REMAINING_BALANCE); ;; pay transfer fees separately, revert on errors
}

() send_on_extend_period(slice user_address, cell acount_code, int end_date, int query_id) impure {
    cell state_init = calculate_account_state_init(my_address(), user_address, acount_code);
    slice account_address = calc_address(state_init);
    var msg = begin_cell()
            .store_msg_flag(msg_flag::bounceable)
            .store_slice(account_address)
            .store_coins(0)
            .store_msgbody_prefix_slice()
            .store_op(op::on_extend_period)
            .store_query_id(query_id)
            .store_uint(end_date, 64);
    send_raw_message(msg.end_cell(), CARRY_REMAINING_BALANCE); ;; pay transfer fees separately, revert on errors
}

() transfer_jetton(slice wallet, slice target_address, slice excess_address, int jetton_amount, int query_id) impure {
    var msg_body = begin_cell()
            .store_op(op::jetton_transfer)
            .store_query_id(query_id) 
            .store_coins(jetton_amount)
            .store_slice(target_address)
            .store_slice(excess_address)
            .store_maybe_ref(null())
            .store_coins(0)
            .store_int(false, 1);

    var msg = begin_cell()
            .store_msg_flag(msg_flag::non_bounceable)
            .store_slice(wallet)
            .store_coins(jetton_transfer_amount)
            .store_msgbody_prefix_ref(msg_body.end_cell());

    send_raw_message(msg.end_cell(), CARRY_REMAINING_BALANCE);
}

() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) { ;; ignore empty messages
        return ();
    }

    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);

    if (flags & 1) {  ;; ignore all bounced messages
        return ();
    }
    
    slice sender_address = cs~load_msg_addr();

    var (owner, staking_acount_code, jetton_wallet, staking_period, min_staking_amount) = load_data();
    if ((staking_period == 0) & (min_staking_amount == 0)) {
        ;; initialize
        jetton_wallet = in_msg_body~load_msg_addr();
        staking_period = in_msg_body~load_uint(64);
        min_staking_amount = in_msg_body~load_coins();

        save_data(owner, staking_acount_code, jetton_wallet, staking_period, min_staking_amount);
        return ();
    }

    int op = in_msg_body~load_uint(32);
    int query_id = in_msg_body~load_uint(64);
  
    int ton_balance_before_msg = my_balance - msg_value;
    raw_reserve(max(ton_balance_before_msg, min_tons_for_storage), 2);

    if (op == op::jetton_transfer_notification) {
        throw_unless(error::unauthorized, equal_slices(sender_address, jetton_wallet));

        int jetton_amount = in_msg_body~load_coins();
        slice user_address = in_msg_body~load_msg_addr();
        if (jetton_amount < min_staking_amount) {
            transfer_jetton(jetton_wallet, user_address, user_address, jetton_amount, query_id);
            return ();
        }

        send_on_supply(user_address, staking_acount_code, jetton_amount, now() + staking_period, query_id);
        return ();
    }

    if (op == op::extend_period) {
        send_on_extend_period(sender_address, staking_acount_code, now() + staking_period, query_id);
        return ();
    }

    if (op == op::on_withdraw) {
        slice user_address = in_msg_body~load_msg_addr();
        int jetton_amount = in_msg_body~load_coins();

        cell state_init = calculate_account_state_init(my_address(), user_address, staking_acount_code);
        slice account_address = calc_address(state_init);

        throw_unless(error::unauthorized, equal_slices(sender_address, account_address));

        transfer_jetton(jetton_wallet, user_address, user_address, jetton_amount, query_id);
        return ();
    }

    if (op == op::set_pool_data) {
        throw_unless(error::unauthorized, equal_slices(sender_address, owner));

        staking_period = in_msg_body~load_uint(64);
        min_staking_amount = in_msg_body~load_coins();

        send_excess(sender_address, query_id);

        save_data(owner, staking_acount_code, jetton_wallet, staking_period, min_staking_amount);
        return ();
    }

    if (op == op::change_admin) { ;; change admin
        throw_unless(error::unauthorized, equal_slices(sender_address, owner));
        save_data(in_msg_body~load_msg_addr(), staking_acount_code, jetton_wallet, staking_period, min_staking_amount);
        return ();
    }

    throw(error::unknown_action);
}

() recv_external(slice in_msg) impure {
}

(slice, slice, int, int) get_pool_data() method_id {
    var (owner, _, jetton_wallet, staking_period, min_staking_amount) = load_data();
    return (owner, jetton_wallet, staking_period, min_staking_amount);
}

slice get_sale_address(slice user_address) method_id {
    var (_, staking_acount_code, _, _, _) = load_data();

    cell state_init = calculate_account_state_init(my_address(), user_address, staking_acount_code);
    return calc_address(state_init);
}

