() msgs::send_empty(int amount, slice to, int mode) impure inline {
    cell msg = begin_cell()
        .store_uint(SEND_MSG_BOUNCEABLE, 6)
        .store_slice(to)
        .store_coins(amount)
        .store_uint(0, 107)
    .end_cell();
    send_raw_message(msg, mode);
}

() msgs::send_simple(int amount, slice to, cell body, int mode) impure inline {
    cell msg = begin_cell()
        .store_uint(SEND_MSG_BOUNCEABLE, 6)
        .store_slice(to)
        .store_coins(amount)
        .store_uint(1, 107)
        .store_ref(body)
    .end_cell();
    send_raw_message(msg, mode);
}

() msgs::send_bsimple(int amount, slice to, builder body, int mode) impure inline {
    cell msg = begin_cell()
        .store_uint(SEND_MSG_BOUNCEABLE, 6)
        .store_slice(to)
        .store_coins(amount)
        .store_uint(0, 107)
        .store_builder(body)
    .end_cell();
    send_raw_message(msg, mode);
}

