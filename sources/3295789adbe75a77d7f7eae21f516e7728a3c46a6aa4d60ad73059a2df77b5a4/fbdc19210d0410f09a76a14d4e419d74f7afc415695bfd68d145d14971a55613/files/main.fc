#include "imports/stdlib.fc";

const const::min_tons_for_storage = 10000000;

(int, slice, slice) get_storage_data() method_id {
    slice ds = get_data().begin_parse();

    return (
        ds~load_uint(32),
        ds~load_msg_addr(),
        ds~load_msg_addr()
    );
}

() save_data(int counter, slice sender, slice owner) impure inline {
    set_data(
        begin_cell()
            .store_uint(counter, 32)
            .store_slice(sender)
            .store_slice(owner)
            .end_cell()
    );
}

() recv_internal(int msg_value, cell in_msg, slice in_msg_body) impure {
    slice ms = in_msg.begin_parse();

    int flags = ms~load_uint(4);

    slice msg_sender = ms~load_msg_addr();

    int op = in_msg_body~load_uint(32);

    (int counter, slice sender, slice owner) = get_storage_data();

    if (op == 1) {
        save_data(counter + 1, msg_sender, owner);
        return();
    }

    if (op == 2) {
        throw_unless(101, equal_slice_bits(msg_sender, owner));

        int withdraw_amount = in_msg_body~load_coins();
        [int balance, _] = get_balance();

        throw_unless(102, withdraw_amount <= balance);

        int return_value = min(withdraw_amount, balance - const::min_tons_for_storage);

        int msg_mode = 1;

        var msg = begin_cell()
            .store_uint(0x18, 6)
            .store_slice(msg_sender)
            .store_coins(return_value)
            .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1);

        send_raw_message(msg.end_cell(), msg_mode);

        return();
    }

    if (op == 3) {
        return();
    }

    throw(777);
}

(int) getBalance() method_id {
    [int balance, _] = get_balance();
    return balance;
}


