#include "../imports/math.fc";

const op::echo = "op::echo"c;

const ONE_TON = 1000000000;
const ONE_TON_DEC = ONE_TON / 10;
const TON10 = ONE_TON * 10;
const TON100 = ONE_TON * 100;
const TON1000 = ONE_TON * 100;
const DENOMINATOR = 100000;

const ZEROADDR = "UQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAJKZ"a;

(slice, int) sdict_get?(cell dict, int key_len, slice index) asm(index dict key_len) "DICTGET" "NULLSWAPIFNOT";
