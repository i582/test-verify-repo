() transfer_to_wallet(slice recipient, int amount) {
    ;; recipient: A slice containing the recipient's address
    ;; amount: The amount of nanograms (1 TON = 1,000,000,000 nanograms) to transfer

    ;; int num = 1000000;
    ;; Create an outbound message
    var out_msg = begin_cell()
        .store_uint(0x10, 6)        ;; msg_flags: 0x10 means carry remaining gas and don't create a new cell
        .store_slice(recipient)     ;; Store the recipient address
        .store_coins(amount)        ;; Store the amount to transfer
        .store_uint(0, 1)           ;; Bounce flag set to 0 (don't bounce the message if it fails)
        .end_cell();                ;; End the cell creation

    ;; Send the message
    send_raw_message(out_msg, 0);  ;; The second argument is the flag, 1 = carry remaining gas
}
