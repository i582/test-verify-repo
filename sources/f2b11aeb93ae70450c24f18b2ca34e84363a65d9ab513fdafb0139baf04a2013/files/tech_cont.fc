;; Storage structure
(int, slice, cell, int) load_data() inline {
    var ds = get_data().begin_parse();
    return (
        ds~load_uint(32),  ;; balance
        ds~load_msg_addr(),  ;; owner
        ds~load_dict(),  ;; bets
        ds~load_uint(0)  ;; is_paused
    );
}

() save_data(int balance, slice owner, cell bets, int is_paused) impure inline {
    set_data(begin_cell()
        .store_uint(balance, 32)
        .store_slice(owner)
        .store_dict(bets)
        .store_uint(is_paused, 1)
        .end_cell());
}

int generate_random(int user_entropy) inline {
    var block_hash = now();
    var combined_entropy = block_hash ^ user_entropy;
    return cell_hash(begin_cell().store_uint(combined_entropy, 256).end_cell()) % 2;
}


