	;; 		.store_uint(query_id, 64)
	;; 		.store_slice(storage::user_address)
	;; 		.store_slice(jetton_wallet_address)
	;; 		.store_coins(storage::amount)			
	;; 		.end_cell();
	;; 	cell msg = begin_cell()
	;; 		.store_uint(0x18, 6)
	;; 		.store_slice(storage::presale_address)
	;; 		.store_coins(0)
	;; 		.store_uint(4 + 2 + 1, 1 + 4 + 4 + 64 + 32 + 1 + 1)
