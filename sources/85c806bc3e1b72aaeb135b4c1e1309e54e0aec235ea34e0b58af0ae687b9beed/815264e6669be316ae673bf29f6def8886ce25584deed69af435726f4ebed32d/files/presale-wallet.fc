#pragma version >=0.2.0;

#include "imports/stdlib.fc";
global slice storage::user_address;
global slice storage::presale_address;
global slice storage::jetton_wallet_address;
global int storage::amount;
global cell storage::wallet_code;

int op::buyNotification() asm "0x301b1bc3 PUSHINT";
int op::claim() asm "0x890442eb PUSHINT";
int op::claimNotification() asm "0xfa78185 PUSHINT";
int op::getAmount() asm "0x5b74f6fa PUSHINT";
int op::getAmountFromWallet() asm "0xec529f1 PUSHINT";
int error::already_claimed() asm "0x9ae8a7e4 PUSHINT";
int error::invalid_amount() asm "0x8247ee60 PUSHINT";
int error::invalid_address() asm "0x4e38d786 PUSHINT";

const WRONG_OP = 0xffff;

() load_storage() impure inline {
    slice ds = get_data().begin_parse();
    storage::user_address = ds~load_msg_addr();
    storage::presale_address = ds~load_msg_addr();
	storage::amount = ds~load_coins();
	storage::wallet_code = ds~load_ref();
}

() save_storage() impure inline {
	set_data(begin_cell()
		.store_slice(storage::user_address)
		.store_slice(storage::presale_address)
		.store_coins(storage::amount)
		.store_ref(storage::wallet_code)
	.end_cell());
}

() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
	load_storage();
       
    if(in_msg_body.slice_empty?())	 {

		return ();
	}

	slice cs = in_msg_full.begin_parse();
	int flags = cs~load_uint(4);
	if (flags & 1) {
		return ();
	}
    slice sender_address = cs~load_msg_addr();
	
