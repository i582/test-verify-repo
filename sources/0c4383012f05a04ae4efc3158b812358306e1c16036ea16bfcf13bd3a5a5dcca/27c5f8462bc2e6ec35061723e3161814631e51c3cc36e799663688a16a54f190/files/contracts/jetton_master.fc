#include "imports/stdlib.fc";
#include "imports/params.fc";
#include "imports/jetton_utils.fc";


;; load dữ liệu lên
(int, slice, cell, cell) load_data() inline {
  slice ds = get_data().begin_parse();
  return (
    ds~load_coins(), ;; total supply
    ds~load_msg_addr(), ;; admin address - địa chỉ ví TON của admin
    ds~load_ref(), ;; Jetton content - dữ liệu về Jetton(tên, logo,...)
    ds~load_ref() ;; Jetton Wallet Code - mã nguồn của code wallet
  );
}

;; lưu dữ liệu
() save_data(int total_supply, slice admin_address, cell content, cell jetton_wallet_code) impure inline {
  cell data = begin_cell().store_coins(total_supply).store_slice(admin_address).store_ref(content).store_ref(jetton_wallet_code).end_cell();
  set_data(data);
}

;; mint token
() mint_tokens(slice to_address, cell jetton_wallet_code, int amount, cell master_msg) impure {
    ;; tạo ví cho người nhận (nếu chưa có)
    ;; Blockchain sẽ tự tạo địa chỉ người nhận msg nếu chưa có dựa trên địa chỉ đích
    cell state_init = calculate_jetton_wallet_state_init(to_address, my_address(), jetton_wallet_code);

    ;; format địa chỉ đích phải tuân thủ (ở đâu là tuân thủ quy tắc của TON)
    slice to_wallet_address = calculate_jetton_wallet_address(state_init);

    ;; Mỗi ví Jetton là 1 SM lưu trữ cell data và code wallet đã được complied
    ;; Để mint vào wallet Jetton cần gửi msg đến trực tiếp smart contract ví Jetton (địa chỉ trên nên tảng TON)
    var msg = begin_cell()
            .store_uint(0x18, 6)
            .store_slice(to_wallet_address) ;; Địa chỉ ví Jetton (trên TON)
            .store_coins(amount) ;; Phí giao dịch trên TON
            .store_uint(4 + 2 + 1, 1 + 4 + 4 + 64 + 32 + 1 + 1 + 1)
            .store_ref(state_init) ;; Msg cần phải có dữ liệu nếu cần để tạo ví mới
            .store_ref(master_msg) ;; Đoạn msg chính cho quá trình mint, chứa lượng Jetton,....
            .end_cell();
    send_raw_message(msg, 1); ;; gửi tin nhắn mint vào ví
}


() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
  
    if (in_msg_body.slice_empty?()) { ;; ignore empty messages
        return ();
    }
    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);

    if (flags & 1) { ;; ignore all bounced messages
        return ();
    }
    slice sender_address = cs~load_msg_addr();
    cs~load_msg_addr(); ;; skip dst
    cs~load_coins(); ;; skip value
    cs~skip_bits(1); ;; skip extracurrency collection
    cs~load_coins(); ;; skip ihr_fee
    int fwd_fee = cs~load_coins(); ;; we use message fwd_fee for estimation of provide_wallet_address cost

    int op = in_msg_body~load_uint(32);
    int query_id = in_msg_body~load_uint(64);

    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();

    if(op == 1){
      throw_unless(73, equal_slices(sender_address, admin_address));
      slice to_address = in_msg_body~load_msg_addr(); ;; load lấy địa chỉ ví TON của người gửi yêu cầu
      int amount = in_msg_body~load_coins(); ;; Lấy sô TON phí mint
      cell master_msg = in_msg_body~load_ref(); ;; Lấy msg chính của yêu cầu
      int jetton_amount = in_msg_body~load_coins();
      mint_tokens(to_address, jetton_wallet_code, amount, master_msg); ;; Mint jetton
      save_data(total_supply + jetton_amount, admin_address, content, jetton_wallet_code); ;; Cập nhật total supply
      return ();
    }
}

;; Trả về thông tin Jetton
(int, int, slice, cell, cell) get_jetton_data() method_id {
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    return (total_supply, -1, admin_address, content, jetton_wallet_code);
}

;; Lấy địa chỉ ví Jetton dựa trên ví TON
slice get_wallet_address(slice owner_address) method_id {
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    return calculate_user_jetton_wallet_address(owner_address, my_address(), jetton_wallet_code);
}