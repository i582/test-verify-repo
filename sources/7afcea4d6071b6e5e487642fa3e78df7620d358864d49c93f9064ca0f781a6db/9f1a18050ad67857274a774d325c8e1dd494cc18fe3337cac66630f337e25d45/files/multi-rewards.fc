        inviter_profile_address = profile_address;
    }

    if (m == 1) {
        if (fill_count == 1) {

            total_paid += send_bonus_msg(
                "structure bounus",     ;; title
                m, 
                place_number, 
                profile_address,        ;; to_address 
                15000000000,            ;; amount 15 TON
                query_id);   

