(cell) get_latest_claims(int count) method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    var (resource_id, data, found) = get_min_entry(claims_data, 256);
    int claim_counter = 0;
    int loop = 1;

    while (data.slice_bits() > 0 & loop & (claim_counter < count)) {
        slice claim_data = data;
        slice user_address = claim_data~load_msg_addr();
        int claim_time = claim_data~load_uint(32);
        int heat = claim_data~load_uint(64);
        int resource_name_len = claim_data.slice_bits() / 8;
        var resource_name_bits = claim_data~load_bits(resource_name_len * 8);
        
        result = result.store_slice(int_to_slice(resource_id));
        result = result.store_slice(user_address);
        result = result.store_uint(claim_time, 32);
        result = result.store_uint(heat, 64);
        result = result.store_slice(resource_name_bits);
        
        var (next_resource_id, next_data, next_found) = get_next_entry(claims_data, 256, resource_id);
        resource_id = next_resource_id;
        data = next_data;
        loop = next_found;
        claim_counter += 1;
    }
    return result.end_cell();
}

(cell) get_resource_claims(slice resource_name) method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    int resource_id = string_hash(resource_name);
    var (data, found) = udict_get?(resources_data, 256, resource_id);
    if (found) {
        while (data.slice_bits() > 0) {
            slice claim_data = data;
            slice user_address = claim_data~load_msg_addr();
            int claim_time = claim_data~load_uint(32);
            result = result.store_slice(user_address);
            result = result.store_uint(claim_time, 32);
        }
    }
    return result.end_cell();
}

int debug_load_total_supply() method_id {
    slice ds = get_data().begin_parse();
    int total_supply = ds~load_coins();
    return total_supply;
}

(slice) debug_load_admin_address() method_id {
    slice ds = get_data().begin_parse();
    ds~load_coins(); ;; Skip total_supply
    slice admin_address = ds~load_msg_addr();
    return admin_address;
}

(cell) debug_load_content() method_id {
    slice ds = get_data().begin_parse();
    ds~load_coins(); ;; Skip total_supply
    ds~load_msg_addr(); ;; Skip admin_address
    cell content = ds~load_ref();
    return content;
}

(cell) debug_load_claims_count() method_id {
    slice ds = get_data().begin_parse();
    
    ;; 调试信息：检查ds是否有效
    if (ds.slice_bits() == 0) {
        return begin_cell().store_uint(900, 32).end_cell();  ;; 调试信息：ds为空
    }
    
    ds~load_coins(); ;; Skip total_supply
    ds~load_msg_addr(); ;; Skip admin_address
    ds~load_ref(); ;; Skip content
    ds~load_ref(); ;; Skip jetton_wallet_code
    
    cell claims_count = ds~load_dict();
    
    ;; 调试信息：检查claims_count是否有效
    if (claims_count.begin_parse().slice_bits() == 0) {
        return begin_cell().store_uint(901, 32).end_cell();  ;; 调试信息：claims_count为空
    }
    
    return claims_count;
}

