(int, slice, cell, cell, cell, cell, cell, cell, cell) debug_load_all_fields() method_id {
    slice ds = get_data().begin_parse();
    
    ;; 调试信息：检查ds是否有效
    if (ds.slice_bits() == 0) {
        return (906, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：ds为空
    }
    
    int total_supply = ds~load_coins();
    slice admin_address = ds~load_msg_addr();
    cell content = ds~load_ref();
    cell jetton_wallet_code = ds~load_ref();
    cell claims_count = ds~load_dict();
    cell degree_heats = ds~load_dict();
    cell claims_data = ds~load_dict();
    cell claim_times = ds~load_dict();
    cell resources_data = ds~load_dict();
    
    ;; 调试信息：检查各字段是否有效
    if (total_supply == 0) {
        return (907, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：total_supply为0
    }
    if (admin_address.slice_bits() == 0) {
        return (908, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：admin_address为空
    }
    if (content.begin_parse().slice_bits() == 0) {
        return (909, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：content为空
    }
    if (jetton_wallet_code.begin_parse().slice_bits() == 0) {
        return (910, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：jetton_wallet_code为空
    }
    if (claims_count.begin_parse().slice_bits() == 0) {
        return (911, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：claims_count为空
    }
    if (degree_heats.begin_parse().slice_bits() == 0) {
        return (912, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：degree_heats为空
    }
    if (claims_data.begin_parse().slice_bits() == 0) {
        return (913, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：claims_data为空
    }
    if (claim_times.begin_parse().slice_bits() == 0) {
        return (914, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：claim_times为空
    }
    if (resources_data.begin_parse().slice_bits() == 0) {
        return (915, null(), null(), null(), null(), null(), null(), null(), null());  ;; 调试信息：resources_data为空
    }
    
    return (total_supply, admin_address, content, jetton_wallet_code, claims_count, degree_heats, claims_data, claim_times, resources_data);
}

(cell) debug_check_extended_data() method_id {
    var (claims_count, degree_heats, claims_data, claim_times, resources_data) = load_extended_data();
    
    if (claims_count.begin_parse().slice_bits() == 0) {
        return begin_cell().store_uint(916, 32).end_cell();  ;; 调试信息：claims_count为空
    }
    if (degree_heats.begin_parse().slice_bits() == 0) {
        return begin_cell().store_uint(917, 32).end_cell();  ;; 调试信息：degree_heats为空
    }
    if (claims_data.begin_parse().slice_bits() == 0) {
        return begin_cell().store_uint(918, 32).end_cell();  ;; 调试信息：claims_data为空
    }
    if (claim_times.begin_parse().slice_bits() == 0) {
        return begin_cell().store_uint(919, 32).end_cell();  ;; 调试信息：claim_times为空
    }
    if (resources_data.begin_parse().slice_bits() == 0) {
        return begin_cell().store_uint(920, 32).end_cell();  ;; 调试信息：resources_data为空
    }

    return begin_cell().store_uint(200, 32).end_cell();  ;; 所有数据都正确
}

(cell) debug_check_claims_data() method_id {
    var (claims_count, degree_heats, claims_data, claim_times, resources_data) = load_extended_data();
    
    ;; 检查 claims_data 是否为空
    var (resource_id, data, found) = get_min_entry(claims_data, 256);
    
    if (found == 0) {
        return begin_cell().store_uint(921, 32).end_cell();  ;; 调试信息：claims_data 为空
    }
    
    return begin_cell().store_uint(107, 32).end_cell();  ;; 调试信息：找到条目
}

(cell) debug_get_claim_data() method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    
    var (resource_id, data, found) = get_min_entry(claims_data, 256);
    
    if (found == 0) {
        return begin_cell().store_uint(922, 32).end_cell();  ;; 调试信息：没有找到条目
    }
    
    if (data.slice_bits() == 0) {
        return begin_cell().store_uint(923, 32).end_cell();  ;; 调试信息：data 为空
    }
    
    slice claim_data = data;
    slice user_address = claim_data~load_msg_addr();
    int claim_time = claim_data~load_uint(32);
    int heat = claim_data~load_uint(64);
    
    result = result.store_uint(1001, 32);  ;; 标记数据类型
    result = result.store_slice(user_address);
    result = result.store_uint(claim_time, 32);
    result = result.store_uint(heat, 64);
    
    return result.end_cell();
}

