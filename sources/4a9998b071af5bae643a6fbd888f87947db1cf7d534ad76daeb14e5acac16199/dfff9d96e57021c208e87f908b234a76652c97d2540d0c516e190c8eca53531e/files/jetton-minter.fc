#include "imports/stdlib.fc";
#include "imports/params.fc";
#include "imports/constants.fc";
#include "imports/jetton-utils.fc";
#include "imports/op-codes.fc";
#include "imports/utils.fc";
#include "imports/discovery-params.fc";

#pragma version >=0.2.0;

(int, slice, cell, cell) load_data() inline {
    slice ds = get_data().begin_parse();
    return (
        ds~load_coins(), ;; total_supply
        ds~load_msg_addr(), ;; admin_address
        ds~load_ref(), ;; content
        ds~load_ref() ;; jetton_wallet_code
    );
}

() save_data(int total_supply, slice admin_address, cell content, cell jetton_wallet_code) impure inline {
    set_data(begin_cell()
        .store_coins(total_supply)
        .store_slice(admin_address)
        .store_ref(content)
        .store_ref(jetton_wallet_code)
        .end_cell()
    );
}

(cell, cell, cell, cell, cell) load_extended_data() inline {
    slice ds = get_data().begin_parse();
    return (
        ds~load_dict(), ;; claims_count
        ds~load_dict(), ;; degree_heats
        ds~load_dict(), ;; claims_data
        ds~load_dict(), ;; claim_times
        ds~load_dict()  ;; resources_data
    );
}

() save_extended_data(cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) impure inline {
    ;; 检查并初始化空字典
    claims_count = claims_count.null?() ? null() : claims_count;
    degree_heats = degree_heats.null?() ? null() : degree_heats;
    claims_data = claims_data.null?() ? null() : claims_data;
    claim_times = claim_times.null?() ? null() : claim_times;
    resources_data = resources_data.null?() ? null() : resources_data;

    set_data(begin_cell()
        .store_ref(claims_count)
        .store_ref(degree_heats)
        .store_ref(claims_data)
        .store_ref(claim_times)
        .store_ref(resources_data)
        .end_cell()
    );
}

() init_null_extended_data() method_id {
    ;; 默认初始数据
    cell claims_count = null();
    cell degree_heats = null();
    cell claims_data = null();
    cell claim_times = null();
    cell resources_data = null();

    ;; 调试信息
    throw(700);

    save_extended_data(claims_count, degree_heats, claims_data, claim_times, resources_data);

    ;; 添加调试信息，表示成功初始化数据
    throw(701);  ;; 调试：初始化完成
}

() set_debug_info(cell info) impure inline {
    set_data(info);
}

() init_extended_data_with_sample() method_id {
    ;; 示例初始化数据
    int key1 = 1;
    int key2 = 2;

    slice value1 = begin_cell().store_uint(100, 32).end_cell().begin_parse();
    slice value2 = begin_cell().store_uint(200, 32).end_cell().begin_parse();

    ;; 初始化字典
    cell claims_count = begin_cell().store_uint(0, 32).end_cell();  ;; 初始字典
    cell degree_heats = begin_cell().store_uint(0, 32).end_cell();
    cell claims_data = begin_cell().store_uint(0, 32).end_cell();
    cell claim_times = begin_cell().store_uint(0, 32).end_cell();
    cell resources_data = begin_cell().store_uint(0, 32).end_cell();

    ;; 存储调试信息到持久存储
    cell debug_info = begin_cell()
        .store_uint(801, 32)
        .end_cell();
    set_debug_info(debug_info);

    ;; 将整数键转换为slice类型
    slice key1_slice = begin_cell().store_uint(key1, 256).end_cell().begin_parse();
    slice key2_slice = begin_cell().store_uint(key2, 256).end_cell().begin_parse();

    ;; 存储调试信息到持久存储
    debug_info = begin_cell()
        .store_uint(802, 32)
        .end_cell();
    set_debug_info(debug_info);

    ;; 设置字典值
    claims_count = dict_set(claims_count, 256, key1_slice, value1);
    claims_count = dict_set(claims_count, 256, key2_slice, value2);

    degree_heats = dict_set(degree_heats, 256, key1_slice, value1);
    degree_heats = dict_set(degree_heats, 256, key2_slice, value2);

    claims_data = dict_set(claims_data, 256, key1_slice, value1);
    claims_data = dict_set(claims_data, 256, key2_slice, value2);

    claim_times = dict_set(claim_times, 256, key1_slice, value1);
    claim_times = dict_set(claim_times, 256, key2_slice, value2);

    ;; 存储调试信息到持久存储
    debug_info = begin_cell()
        .store_uint(803, 32)
        .end_cell();
    set_debug_info(debug_info);

    resources_data = dict_set(resources_data, 256, key1_slice, value1);
    resources_data = dict_set(resources_data, 256, key2_slice, value2);

    ;; 存储调试信息到持久存储
    debug_info = begin_cell()
        .store_uint(804, 32)
        .end_cell();
    set_debug_info(debug_info);

    save_extended_data(
        claims_count,
        degree_heats,
        claims_data,
        claim_times,
        resources_data
    );

    ;; 存储调试信息到持久存储
    debug_info = begin_cell()
        .store_uint(805, 32)
        .end_cell();
    set_debug_info(debug_info);
}

(cell) get_debug_info() method_id {
    return get_data();
}

() mint_tokens(slice to_address, cell jetton_wallet_code, int amount, cell master_msg) impure {
    cell state_init = calculate_jetton_wallet_state_init(to_address, my_address(), jetton_wallet_code);
    slice to_wallet_address = calculate_jetton_wallet_address(state_init);
    var msg = begin_cell()
            .store_uint(0x18, 6)
            .store_slice(to_wallet_address)
            .store_coins(amount)
            .store_uint(4 + 2 + 1, 1 + 4 + 4 + 64 + 32 + 1 + 1 + 1)
            .store_ref(state_init)
            .store_ref(master_msg);
    send_raw_message(msg.end_cell(), 1); ;; pay transfer fees separately, revert on errors
}

slice int_to_slice(int value) inline {
    return begin_cell().store_uint(value, 32).end_cell().begin_parse();
}

slice fixed_point_to_slice(int value, int decimals) inline {
    return begin_cell().store_uint(value, 64).store_uint(decimals, 8).end_cell().begin_parse();
}

(int, int) slice_to_fixed_point(slice s) inline {
    return (s~load_uint(64), s~load_uint(8));
}

int power(int base, int exp) inline {
    int result = 1;
    int i = 0;
    while (i < exp) {
        result *= base;
        i += 1;
    }
    return result;
}

() claim_resource(slice sender_address, slice resource_name) impure {
    int resource_id = string_hash(resource_name); ;; Convert resource name to hash
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();

    int current_time = now();
    var (claims_opt, found) = udict_get?(claims_count, 256, resource_id);
    int claims = found ? claims_opt~load_uint(32) : 0;
    claims = claims + 1;
    claims_count = udict_set(claims_count, 256, resource_id, int_to_slice(claims));

    int base = 1000000; ;; 定点数基数
    int heat = base * power(11, claims) / power(10, claims); ;; 使用定点数计算热度
    degree_heats = udict_set(degree_heats, 256, resource_id, fixed_point_to_slice(heat, 6));

    cell claim_data = begin_cell()
        .store_slice(sender_address)
        .store_uint(current_time, 32)
        .store_uint(heat, 64)
        .store_slice(resource_name)
        .end_cell();
    claims_data = udict_set(claims_data, 256, resource_id, claim_data.begin_parse());

    cell resource_claim_data = begin_cell()
        .store_slice(sender_address)
        .store_uint(current_time, 32)
        .end_cell();
    resources_data = udict_set(resources_data, 256, resource_id, resource_claim_data.begin_parse());

    save_extended_data(claims_count, degree_heats, claims_data, claim_times, resources_data);
}

() send_internal_message(slice to, int amount, int bounce, int flags) inline {
    cell msg = begin_cell()
        .store_slice(to)
        .store_uint(bounce, 1)
        .store_uint(flags, 1)
        .end_cell();
    send_raw_message(msg, amount);
}

int to_nano(int ton_value) inline {
    return ton_value * 1000000000;
}

(int, slice, int) get_min_entry(cell dict, int key_len) inline {
    var (entry_key, entry_value, found) = udict_get_next?(dict, key_len, 0);
    return (entry_key, entry_value, found);
}

(int, slice, int) get_next_entry(cell dict, int key_len, int prev_key) inline {
    var (entry_key, entry_value, found) = udict_get_next?(dict, key_len, prev_key);
    return (entry_key, entry_value, found);
}

(int) claim_reward(slice sender_address) impure {
    ;; 加载扩展数据
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();

    ;; 计算发送者的哈希值
    int sender_hash = slice_hash(sender_address);

    ;; 获取最后领取奖励的时间
    var (last_claim_time_opt, found) = udict_get?(claim_times, 256, sender_hash);
    int last_claim_time = found ? last_claim_time_opt~load_uint(32) : 0;
    int current_time = now();

    ;; 检查领取奖励是否太早
    throw_if(100, current_time - last_claim_time < 3600);

    int total_reward = 0;
    ;; 获取 claims_data 字典中的最小条目
    var (resource_id, claim_cell_opt, found) = get_min_entry(claims_data, 256);
    while (found) {
        slice claim_data = claim_cell_opt;
        slice user_address = claim_data~load_msg_addr();
        int claim_time = claim_data~load_uint(32);
        int heat = claim_data~load_uint(64);

        ;; 获取资源 ID 对应的声明次数
        var (claims_opt, found_claims) = udict_get?(claims_count, 256, resource_id);
        int claims = found_claims ? claims_opt~load_uint(32) : 1;
        if (equal_slices(user_address, sender_address)) {
            total_reward += heat / claims;
        }

        ;; 获取下一个条目
        var (next_resource_id, next_claim_cell_opt, next_found) = get_next_entry(claims_data, 256, resource_id);
        resource_id = next_resource_id;
        claim_cell_opt = next_claim_cell_opt;
        found = next_found;
    }

    ;; 更新 claim_times 字典
    claim_times = udict_set(claim_times, 256, sender_hash, int_to_slice(current_time));

    ;; 发送奖励Jetton代币
    mint_tokens(sender_address, jetton_wallet_code, total_reward, begin_cell().end_cell());

    ;; 保存扩展数据
    save_extended_data(claims_count, degree_heats, claims_data, claim_times, resources_data);

    ;; 返回奖励值
    return total_reward;
}

(int, int, slice, cell, cell) get_jetton_data() method_id {
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    return (total_supply, -1, admin_address, content, jetton_wallet_code);
}

slice get_wallet_address(slice owner_address) method_id {
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    return calculate_user_jetton_wallet_address(owner_address, my_address(), jetton_wallet_code);
}

(cell) get_claims(slice claimer_address) method_id {
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    var (resource_id, data, found) = get_min_entry(claims_data, 256);
    int loop = 1;
    while (data.slice_bits() > 0 & loop) {
        slice claim_data = data;
        slice user_address = claim_data~load_msg_addr();
        int claim_time = claim_data~load_uint(32);
        int heat = claim_data~load_uint(64);
        int resource_name_len = claim_data.slice_bits() / 8;
        var resource_name_bits = claim_data~load_bits(resource_name_len * 8);
        if (equal_slices(user_address, claimer_address)) {
            result = result.store_slice(int_to_slice(resource_id));
            result = result.store_slice(user_address);
            result = result.store_uint(claim_time, 32);
            result = result.store_uint(heat, 64);
            result = result.store_slice(resource_name_bits);
        }
        var (next_resource_id, next_data, next_found) = get_next_entry(claims_data, 256, resource_id);
        resource_id = next_resource_id;
        data = next_data;
        loop = next_found;
    }
    return result.end_cell();
}

(cell) get_all_claims() method_id {
    (int total_supply, slice admin_address, cell content, cell jetton_wallet_code) = load_data();
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    var (resource_id, data, found) = get_min_entry(claims_data, 256);
    int loop = 1;
    while (data.slice_bits() > 0 & loop) {
        slice claim_data = data;
        slice user_address = claim_data~load_msg_addr();
        int claim_time = claim_data~load_uint(32);
        int heat = claim_data~load_uint(64);
        int resource_name_len = claim_data.slice_bits() / 8;
        var resource_name_bits = claim_data~load_bits(resource_name_len * 8);
        
        result = result.store_slice(int_to_slice(resource_id));
        result = result.store_slice(user_address);
        result = result.store_uint(claim_time, 32);
        result = result.store_uint(heat, 64);
        result = result.store_slice(resource_name_bits);
        
        var (next_resource_id, next_data, next_found) = get_next_entry(claims_data, 256, resource_id);
        resource_id = next_resource_id;
        data = next_data;
        loop = next_found;
    }
    return result.end_cell();
}

(cell) get_all_claims_step1() method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    return begin_cell().end_cell();
}
(cell) get_all_claims_step2() method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    return result.end_cell();
}
(cell) get_all_claims_step3() method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    var (resource_id, data, found) = get_min_entry(claims_data, 256);
    return result.end_cell();
}

(cell) get_all_claims_step4() method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
    var (resource_id, data, found) = get_min_entry(claims_data, 256);

    ;; 检查是否找到条目
    if (found == 0) {
        return begin_cell().store_uint(103, 32).end_cell();  ;; 调试信息：没有找到条目
    }

    ;; 添加调试日志，检查 data 的值
    if (data.slice_bits() == 0) {
        return begin_cell().store_uint(100, 32).end_cell();  ;; 调试信息：data 为空
    }

    while (found) {
        if (data.slice_bits() > 0) {
            slice claim_data = data;

            ;; 再次检查 claim_data 的值
            if (claim_data.slice_bits() == 0) {
                return begin_cell().store_uint(104, 32).end_cell();  ;; 调试信息：claim_data 为空
            }

            ;; 处理 claim_data 内容
            slice user_address = claim_data~load_msg_addr();
            if (user_address.slice_bits() == 0) {
                return begin_cell().store_uint(105, 32).end_cell();  ;; 调试信息：user_address 为空
            }

            int claim_time = claim_data~load_uint(32);
            if (claim_time == 0) {
                return begin_cell().store_uint(106, 32).end_cell();  ;; 调试信息：claim_time 为 0
            }

            int heat = claim_data~load_uint(64);
            if (heat == 0) {
                return begin_cell().store_uint(107, 32).end_cell();  ;; 调试信息：heat 为 0
            }

            int resource_name_len = claim_data.slice_bits() / 8;
            var resource_name_bits = claim_data~load_bits(resource_name_len * 8);
            if (resource_name_bits.slice_bits() == 0) {
                return begin_cell().store_uint(108, 32).end_cell();  ;; 调试信息：resource_name_bits 为空
            }

            ;; 存储提取的数据到结果中
            result = result.store_slice(user_address);
            result = result.store_uint(claim_time, 32);
            result = result.store_uint(heat, 64);
            result = result.store_slice(resource_name_bits);

            ;; 获取下一个条目
            var (next_resource_id, next_data, next_found) = get_next_entry(claims_data, 256, resource_id);
            resource_id = next_resource_id;
            data = next_data;
            found = next_found;
        } else {
            found = 0;  ;; 结束循环
        }
    }

    return result.end_cell();
}

(cell) get_all_claims_step5() method_id {
    (cell claims_count, cell degree_heats, cell claims_data, cell claim_times, cell resources_data) = load_extended_data();
    builder result = begin_cell();
