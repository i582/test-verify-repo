#include "../imports/stdlib.fc";
#include "../imports/params.fc";
#include "../imports/messages.fc";
#include "op-codes.fc";
#include "error-codes.fc";

const int op::jetton_transfer = 0xf8a7ea5;
const int op::jetton_transfer_notification = 0x7362d09c;
const int burn_amount = 10000000; ;; 0.01 TON

() transfer_jetton(slice wallet, slice target_address, slice excess_address, cell payload, int jetton_amount, int query_id) impure {
    var msg_body = begin_cell()
            .store_op(op::jetton_transfer)
            .store_query_id(query_id) 
            .store_coins(jetton_amount)
            .store_slice(target_address)
            .store_slice(excess_address)
            .store_maybe_ref(null())
            .store_coins(0)
            .store_maybe_ref(payload);

    var msg = begin_cell()
            .store_msg_flag(msg_flag::non_bounceable)
            .store_slice(wallet)
            .store_coins(0)
            .store_msgbody_prefix_ref(msg_body.end_cell());

    send_raw_message(msg.end_cell(), CARRY_REMAINING_BALANCE);
}

;; NFT collection smart contract

(slice, int, slice, slice, int, cell, cell, cell) load_data() inline {
  var ds = get_data().begin_parse();
  return 
    (ds~load_msg_addr(), ;; owner_address
     ds~load_uint(64),   ;; next_item_index
     ds~load_msg_addr(), ;; collection jetton wallet address (merge)
     ds~load_msg_addr(), ;; merge payment receiver jetton wallet address
     ds~load_coins(),    ;; min_merge_price
     ds~load_ref(), ;; content
     ds~load_ref(), ;; nft_item_code
     ds~load_ref()  ;; royalty_params
     );
}

() save_data(slice owner_address, int next_item_index, slice collection_wallet, slice merge_wallet_owner, int min_merge_price, cell content, cell nft_item_code, cell royalty_params) impure inline {
  set_data(begin_cell()
    .store_slice(owner_address)
    .store_uint(next_item_index, 64)
    .store_slice(collection_wallet)
    .store_slice(merge_wallet_owner)
    .store_coins(min_merge_price)
    .store_ref(content)
    .store_ref(nft_item_code)
    .store_ref(royalty_params)
    .end_cell());
}

cell calculate_nft_item_state_init(int item_index, cell nft_item_code) {
  cell data = begin_cell().store_uint(item_index, 64).store_slice(my_address()).end_cell();
  return begin_cell().store_uint(0, 2).store_dict(nft_item_code).store_dict(data).store_uint(0, 1).end_cell();
}

slice calculate_nft_item_address(int wc, cell state_init) {
  return begin_cell().store_uint(4, 3)
                     .store_int(wc, 8)
                     .store_uint(cell_hash(state_init), 256)
                     .end_cell()
                     .begin_parse();
}

() deploy_nft_item(int item_index, cell nft_item_code, int amount, cell nft_content) impure {
  cell state_init = calculate_nft_item_state_init(item_index, nft_item_code);
  slice nft_address = calculate_nft_item_address(workchain, state_init);
  var msg = begin_cell()
            .store_uint(0x18, 6)
            .store_slice(nft_address)
            .store_coins(amount)
            .store_uint(4 + 2 + 1, 1 + 4 + 4 + 64 + 32 + 1 + 1 + 1)
            .store_ref(state_init)
            .store_ref(nft_content);
  send_raw_message(msg.end_cell(), 1); ;; pay transfer fees separately, revert on errors
}

() send_royalty_params(slice to_address, int query_id, slice data) impure inline {
  var msg = begin_cell()
    .store_uint(0x10, 6) ;; nobounce - int_msg_info$0 ihr_disabled:Bool bounce:Bool bounced:Bool src:MsgAddress -> 011000
    .store_slice(to_address)
    .store_coins(0)
    .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
    .store_uint(op::report_royalty_params(), 32)
    .store_uint(query_id, 64)
    .store_slice(data);
  send_raw_message(msg.end_cell(), 64); ;; carry all the remaining value of the inbound message
}

() send_burn(slice nft_address, slice owner_address) impure inline {
  var msg = begin_cell()
    .store_uint(0x10, 6) ;; nobounce - int_msg_info$0 ihr_disabled:Bool bounce:Bool bounced:Bool src:MsgAddress -> 011000
    .store_slice(nft_address)
    .store_coins(burn_amount)
    .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
    .store_uint(op::burn, 32)
    .store_uint(0, 64)
    .store_slice(owner_address);
  send_raw_message(msg.end_cell(), 1); ;; pay transfer fees separately, revert on errors
}

() merge_nft(slice collection_wallet, slice merge_wallet_owner, int min_merge_price, slice in_msg_body, int query_id) impure inline {
  int jetton_amount = in_msg_body~load_coins();
  slice from_address = in_msg_body~load_msg_addr();

  if (jetton_amount < min_merge_price) {
      ;; return jetton back
      transfer_jetton(collection_wallet, from_address, from_address, null(), jetton_amount, query_id);
      return ();
  }

  slice nftData = in_msg_body~load_ref().begin_parse();
  slice nft1 = nftData~load_msg_addr();
  slice nft2 = nftData~load_msg_addr();

  send_burn(nft1, from_address);
  send_burn(nft2, from_address);

  cell payload = begin_cell().store_slice(nft1).store_slice(nft2).end_cell();
  transfer_jetton(collection_wallet, merge_wallet_owner, from_address, payload, jetton_amount, query_id);
}

() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) { ;; ignore empty messages
      return ();
    }
    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);
    
    if (flags & 1) { ;; ignore all bounced messages
      return ();
    }

    var (owner_address, next_item_index, collection_wallet, merge_wallet_owner, min_merge_price, content, nft_item_code, royalty_params) = load_data();
    if ((min_merge_price == 0) & (equal_slices(owner_address, collection_wallet))) {
      ;; initialize
      collection_wallet = in_msg_body~load_msg_addr();
      min_merge_price = in_msg_body~load_coins();
      save_data(owner_address, next_item_index, collection_wallet, merge_wallet_owner, min_merge_price, content, nft_item_code, royalty_params);
      return ();
    }

    slice sender_address = cs~load_msg_addr();

    int op = in_msg_body~load_uint(32);
    int query_id = in_msg_body~load_uint(64);

    if (op == op::get_royalty_params()) {
      send_royalty_params(sender_address, query_id, royalty_params.begin_parse());
      return ();
    }

    if (op == op::jetton_transfer_notification) {
      raw_reserve(my_balance - msg_value, 0);

      throw_unless(error::unauthorized, equal_slices(sender_address, collection_wallet));
      merge_nft(collection_wallet, merge_wallet_owner, min_merge_price, in_msg_body, query_id);
      return ();
    }

    throw_unless(error::unauthorized, equal_slices(sender_address, owner_address));
  
    if (op == 1) { ;; deploy new nft
      int item_index = in_msg_body~load_uint(64);
      throw_unless(error::wrong_item_index, item_index <= next_item_index);
      var is_last = item_index == next_item_index;
      deploy_nft_item(item_index, nft_item_code, in_msg_body~load_coins(), in_msg_body~load_ref());
      if (is_last) {
        next_item_index += 1;
        save_data(owner_address, next_item_index, collection_wallet, merge_wallet_owner, min_merge_price, content, nft_item_code, royalty_params);
      }
      return ();
    }
    if (op == 2) { ;; batch deploy of new nfts
      int counter = 0;
      cell deploy_list = in_msg_body~load_ref();
      do {
        var (item_index, item, f?) = deploy_list~udict::delete_get_min(64);
        if (f?) {
          counter += 1;
          if (counter >= 250) { ;; Limit due to limits of action list size
            throw(error::action_limit_exceed);
          }

          throw_unless(error::wrong_item_index_batch + counter, item_index <= next_item_index);
          deploy_nft_item(item_index, nft_item_code, item~load_coins(), item~load_ref());
          if (item_index == next_item_index) {
            next_item_index += 1;
          }
        }
      } until ( ~ f?);
      save_data(owner_address, next_item_index, collection_wallet, merge_wallet_owner, min_merge_price, content, nft_item_code, royalty_params);
      return ();
    }
    if (op == 3) { ;; change owner
      slice new_owner = in_msg_body~load_msg_addr();
      save_data(new_owner, next_item_index, collection_wallet, merge_wallet_owner, min_merge_price, content, nft_item_code, royalty_params);
      return ();
    }
    if (op == 4) { ;; set merge params
      merge_wallet_owner = in_msg_body~load_msg_addr();
      min_merge_price = in_msg_body~load_coins();
      save_data(owner_address, next_item_index, collection_wallet, merge_wallet_owner, min_merge_price, content, nft_item_code, royalty_params);
      return ();
    }
    throw(error::unknown_action);
}

;; Get methods

(int, cell, slice) get_collection_data() method_id {
  var (owner_address, next_item_index, _, _, _, content, _, _) = load_data();
  slice cs = content.begin_parse();
  return (next_item_index, cs~load_ref(), owner_address);
}

slice get_nft_address_by_index(int index) method_id {
    var (_, _, _, _, _, _, nft_item_code, _) = load_data();
    cell state_init = calculate_nft_item_state_init(index, nft_item_code);
    return calculate_nft_item_address(workchain, state_init);
}

(int, int, slice) royalty_params() method_id {
     var (_, _, _, _, _, _, _, royalty) = load_data();
     slice rs = royalty.begin_parse();
     return (rs~load_uint(16), rs~load_uint(16), rs~load_msg_addr());
}

cell get_nft_content(int index, cell individual_nft_content) method_id {
  var (_, _, _, _, _, content, _, _) = load_data();
  slice cs = content.begin_parse();
  cs~load_ref();
  slice common_content = cs~load_ref().begin_parse();
  return (begin_cell()
                      .store_uint(1, 8) ;; offchain tag
                      .store_slice(common_content)
                      .store_ref(individual_nft_content)
          .end_cell());
}

(slice, slice, int) get_merge_data() method_id {
  var (_, _, collection_wallet, merge_wallet_owner, min_merge_price, _, _, _) = load_data();
  return (collection_wallet, merge_wallet_owner, min_merge_price);
}
