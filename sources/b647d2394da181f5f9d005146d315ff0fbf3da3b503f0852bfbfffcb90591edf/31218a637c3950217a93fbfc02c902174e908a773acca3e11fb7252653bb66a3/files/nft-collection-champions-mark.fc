#include "nftimports/stdlib.fc";
#include "nftimports/op-codes.fc";
#include "nftimports/params.fc";
#include "./helpers.fc";

;; Champion Mark NFT collection smart contract

;; storage scheme
;; default#_ royalty_factor:uint16 royalty_base:uint16 royalty_address:MsgAddress = RoyaltyParams;
;; storage#_ owner_address:MsgAddress next_item_index:uint64
;;           ^[collection_content:^Cell common_content:^Cell]
;;           nft_item_code:^Cell
;;           royalty_params:^RoyaltyParams
;;           = Storage;

(slice, int, int, cell, cell, cell, cell) load_data() inline {
  var ds = get_data().begin_parse();
  return
    (ds~load_msg_addr(), ;; owner_address
     ds~load_uint(256), ;; public_key
     ds~load_uint(64), ;; next_item_index
     ds~load_ref(), ;; content
     ds~load_ref(), ;; nft_item_code
     ds~load_ref(),  ;; royalty_params
     ds~load_dict() ;; nft_claim_info
     );
}

() save_data(slice owner_address, int public_key, int next_item_index, cell content, cell nft_item_code, cell royalty_params, cell nft_claim_info) impure inline {
  set_data(begin_cell()
    .store_slice(owner_address)
    .store_uint(public_key, 256)
    .store_uint(next_item_index, 64)
    .store_ref(content)
    .store_ref(nft_item_code)
    .store_ref(royalty_params)
    .store_dict(nft_claim_info)
    .end_cell());
}

cell calculate_nft_item_state_init(int item_index, cell nft_item_code) {
  cell data = begin_cell().store_uint(item_index, 64).store_slice(my_address()).end_cell();
  return begin_cell().store_uint(0, 2).store_dict(nft_item_code).store_dict(data).store_uint(0, 1).end_cell();
}

slice calculate_nft_item_address(int wc, cell state_init) {
  return begin_cell().store_uint(4, 3)
                     .store_int(wc, 8)
                     .store_uint(cell_hash(state_init), 256)
                     .end_cell()
                     .begin_parse();
}

() deploy_nft_item(int item_index, cell nft_item_code, int amount, cell nft_content) impure {
  cell state_init = calculate_nft_item_state_init(item_index, nft_item_code);
  slice nft_address = calculate_nft_item_address(workchain(), state_init);
  var msg = begin_cell()
            .store_uint(0x18, 6)
            .store_slice(nft_address)
            .store_coins(amount)
            .store_uint(4 + 2 + 1, 1 + 4 + 4 + 64 + 32 + 1 + 1 + 1)
            .store_ref(state_init)
            .store_ref(nft_content);
  send_raw_message(msg.end_cell(), 1); ;; pay transfer fees separately, revert on errors
}

() send_royalty_params(slice to_address, int query_id, slice data) impure inline {
  var msg = begin_cell()
    .store_uint(0x10, 6) ;; nobounce - int_msg_info$0 ihr_disabled:Bool bounce:Bool bounced:Bool packages:MsgAddress -> 011000
    .store_slice(to_address)
    .store_coins(0)
    .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
    .store_uint(op::report_royalty_params(), 32)
    .store_uint(query_id, 64)
    .store_slice(data);
  send_raw_message(msg.end_cell(), 64); ;; carry all the remaining value of the inbound message
}


slice pack_nft_claim_info( int nft_item_count, int nft_nonce) inline {
    cell data = begin_cell()
        .store_uint(nft_item_count, 32)
        .store_uint(nft_nonce, 32)
    .end_cell();
    return data.begin_parse();
}

(int, int) unpack_nft_claim_info(slice data) inline {
    return (data~load_uint(32), data~load_uint(32));
}


() recv_internal(int my_balance, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) { ;; ignore empty messages
        return ();
    }
    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);

    if (flags & 1) { ;; ignore all bounced messages
        return ();
    }
    slice sender_address = cs~load_msg_addr();

    int op = in_msg_body~load_uint(32);
    int query_id = in_msg_body~load_uint(64);

    var (owner_address, public_key, next_item_index, content, nft_item_code, royalty_params, nft_claim_dict) = load_data();

    if (op == op::get_royalty_params()) {
        send_royalty_params(sender_address, query_id, royalty_params.begin_parse());
        return ();
    }

    if (op == op::top_up()) {
        return (); ;; just accept tons
    }

    if (op == 5) { ;; claim nft
      int item_claim_count = in_msg_body~load_uint(64);
      int item_count = 0;
      int nonce = 1;
      (_, int key) = parse_std_addr(sender_address);
      (slice nft_claim_info_slice, int exists) = nft_claim_dict.udict_get?(256, key);
      if (exists){
        item_count = nft_claim_info_slice~load_uint(32);
        nonce = nft_claim_info_slice~load_uint(32);
      } 
      ;; Verify the signature
      cell ref = in_msg_body~load_ref();
      slice ref_cs = ref.begin_parse();
      slice signature = ref_cs~load_bits(512);
      cell cell_to_hash = begin_cell()
                            .store_slice(my_address())
                            .store_slice(sender_address)
                            .store_uint(nonce, 32)
                            .end_cell();

      throw_unless(405, check_signature(cell_hash(cell_to_hash), signature, public_key));
      nonce += 1;

      cell item_ref = in_msg_body~load_ref();
      int amount = in_msg_body~load_coins();
      ;; batch nft
      int counter = 0;
      int item_index = next_item_index;
      do {
          counter += 1;
          if (counter >= 250) { ;; Limit due to limits of action list size
            throw(399);
          }

          (_, _, next_item_index, _, _, _, _) = load_data();

          ifnot (item_index == next_item_index){
            item_index = next_item_index;
          }

          deploy_nft_item(item_index, nft_item_code, amount, item_ref);
          if (item_index == next_item_index) {
            item_index += 1;
            next_item_index += 1;
            item_count += 1;
            save_data(owner_address, public_key, next_item_index, content, nft_item_code, royalty_params, nft_claim_dict);
          }
      } until ( item_claim_count == counter);
      
      slice packed_data = pack_nft_claim_info(item_count, nonce);
      nft_claim_dict~udict_set(256, key, packed_data);
      save_data(owner_address, public_key, next_item_index + 1 , content, nft_item_code, royalty_params, nft_claim_dict);

      return ();
    }

    throw_unless(401, equal_slices(sender_address, owner_address));

    if (op == 1) { ;; deploy new nft
      int item_index = in_msg_body~load_uint(64);
      throw_unless(402, item_index <= next_item_index);
      var is_last = item_index == next_item_index;
      deploy_nft_item(item_index, nft_item_code, in_msg_body~load_coins(), in_msg_body~load_ref());
      if (is_last) {
        next_item_index += 1;
        save_data(owner_address, public_key, next_item_index, content, nft_item_code, royalty_params, nft_claim_dict);
      }
      return ();
    }
    if (op == 2) { ;; batch deploy of new nfts
      int counter = 0;
      cell deploy_list = in_msg_body~load_ref();
      do {
        var (item_index, item, f?) = deploy_list~udict::delete_get_min(64);
        if (f?) {
          counter += 1;
          if (counter >= 250) { ;; Limit due to limits of action list size
            throw(399);
          }

          throw_unless(403 + counter, item_index <= next_item_index);
          deploy_nft_item(item_index, nft_item_code, item~load_coins(), item~load_ref());
          if (item_index == next_item_index) {
            next_item_index += 1;
          }
        }
      } until ( ~ f?);
      save_data(owner_address, public_key, next_item_index, content, nft_item_code, royalty_params, nft_claim_dict);
      return ();
    }
    if (op == 3) { ;; change owner
      slice new_owner = in_msg_body~load_msg_addr();
      save_data(new_owner, public_key, next_item_index, content, nft_item_code, royalty_params, nft_claim_dict);
      return ();
    }
    if (op == 4) { ;; change content
      save_data(owner_address, public_key, next_item_index, in_msg_body~load_ref(), nft_item_code, in_msg_body~load_ref(), nft_claim_dict);
      return ();
    }
    if (op == 6) { ;; withdraw ton
        int MIN_TON_FOR_STORAGE = 50000000; 

        in_msg_body.end_parse();
        throw_unless(92, my_balance > MIN_TON_FOR_STORAGE);
        raw_reserve(MIN_TON_FOR_STORAGE, RESERVE_REGULAR);

        cell msg = begin_cell()
            .store_msg_flags_and_address_none(NON_BOUNCEABLE)
            .store_slice(owner_address)
            .store_coins(0)
            .store_prefix_only_body()
            .store_uint(op::top_up(), 32)
            .store_uint(query_id, 64)
            .end_cell();
        send_raw_message(msg, SEND_MODE_CARRY_ALL_BALANCE);
        return ();
    }
    if (op == 7) { ;; update public_key
      save_data(owner_address, in_msg_body~load_uint(256), next_item_index, content, nft_item_code, royalty_params, nft_claim_dict);
      return ();
    }

    throw(0xffff);
}

;; Get methods

(int, cell, slice) get_collection_data() method_id {
  var (owner_address, _, next_item_index, content, _, _, _) = load_data();
  slice cs = content.begin_parse();
  return (next_item_index, cs~load_ref(), owner_address);
}

slice get_nft_address_by_index(int index) method_id {
    var (_, _, _, _, nft_item_code, _, _) = load_data();
    cell state_init = calculate_nft_item_state_init(index, nft_item_code);
    return calculate_nft_item_address(0, state_init);
}

(int, int, slice) royalty_params() method_id {
    var (_, _, _, _, _, royalty, _) = load_data();
    slice rs = royalty.begin_parse();
    return (rs~load_uint(16), rs~load_uint(16), rs~load_msg_addr());
}

cell get_nft_content(int index, cell individual_nft_content) method_id {
  var (_, _, _, content, _, _, _) = load_data();
  slice cs = content.begin_parse();
  cs~load_ref();
  slice common_content = cs~load_ref().begin_parse();
  return (begin_cell()
                      .store_uint(1, 8) ;; offchain tag
                      .store_slice(common_content)
                      .store_ref(individual_nft_content)
          .end_cell());
}

(int, int) get_nft_claim_info_by_address(slice address) method_id {
  var (_, _, _, _, _, _, nft_claim_dict) = load_data();
  (_, int key) = parse_std_addr(address);
  (slice nft_claim_info_slice, int exists) = nft_claim_dict.udict_get?(256, key);
  int item_count = 0;
  int nonce = 1;
  if (exists){
    item_count = nft_claim_info_slice~load_uint(32);
    nonce = nft_claim_info_slice~load_uint(32);
  }

  return (item_count, nonce);
}
