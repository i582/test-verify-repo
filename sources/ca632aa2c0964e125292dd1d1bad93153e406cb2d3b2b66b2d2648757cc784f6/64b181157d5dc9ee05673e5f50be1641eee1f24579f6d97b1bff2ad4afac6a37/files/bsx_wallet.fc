#include "imports/stdlib.fc";
#include "./helpers.fc";
const op::transfer_notification = 0x7362d09c;
const op::transfer = 0xf8a7ea5;

const op::buy_item_ton = "op::buy_item_ton"c; 
const op::top_up = "op::top_up"c; 
const op::withdraw_ton = "op::withdraw_ton"c; 
const op::withdraw_jetton = "op::withdraw_jetton"c; 
const op::update_public_key = "op::update_public_key"c; 
const op::claim_ton = "op::claim_ton"c; 
const op::claim_jetton = "op::claim_jetton"c; 
const op::set_valid_jetton = "op::set_valid_jetton"c; 

const int error::invalid_amount = 87;
const int error::invalid_quantity = 88;
const int error::deadline_expired = 94;
const int error::invalid_signature = 96;
const int error::invalid_payment_type = 97;
const int error::unauthorized_address = 401;
const int log::buy_item_ton = 0x1; 
const int log::buy_item_jetton = 0x2; 
const int log::claim_ton = 0x3; 
const int log::claim_jetton = 0x4; 

;; storage variables
global int ctx_id;
global slice owner_address;
global int public_key;
global cell user_seq_no_dict;
global cell valid_jetton;

;; load_data populates storage variables using stored data
() load_data() impure {
    var ds = get_data().begin_parse();

    ctx_id = ds~load_uint(32);
    owner_address = ds~load_msg_addr();
    public_key = ds~load_uint(256);
    user_seq_no_dict = ds~load_dict();
    valid_jetton = slice_empty?(ds) ? new_dict() : ds~load_dict();

    ds.end_parse();
}

;; save_data stores storage variables as a cell into persistent storage
() save_data() impure {
    set_data(
        begin_cell()
            .store_uint(ctx_id, 32)
            .store_slice(owner_address)
            .store_uint(public_key, 256)
            .store_dict(user_seq_no_dict)
            .store_dict(valid_jetton)
            .end_cell()
    );
}

builder store_log(builder b, builder log) inline {
    return log.builder_bits() <= 654
        ? b.store_uint(0, 1).store_builder(log)
        : b.store_maybe_ref(log.end_cell());
}

() emit_log(int topic, builder log) impure inline_ref {
    cell msg = begin_cell()
        .store_uint(0x31, 2 + 2 + 2) 
        .store_uint(256, 9)
        .store_uint(topic, 256)
        .store_uint(0, 64 + 32 + 1)
        .store_log(log)
        .end_cell();
    send_raw_message(msg, 0);
}

;; recv_internal is the main function of the contract and is called when it receives a message from other contracts
() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) { ;; ignore all empty messages
        return ();
    }

    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);
    if (flags & 1) { ;; ignore all bounced messages
        return ();
    }

    load_data(); ;; here we populate the storage variables

    slice sender_address = cs~load_msg_addr();
    int op = in_msg_body~load_uint(32); ;; by convention, the first 32 bits of incoming message is the op
    int query_id = in_msg_body~load_uint(64); ;; also by convention, the next 64 bits contain the "query id", although this is not always the case

    if (op == op::top_up) {
        return (); ;; just accept tons
    }

    if (op == op::buy_item_ton) {
        cell ref = in_msg_body~load_ref();
        slice ref_cs = ref.begin_parse();
        slice signature = ref_cs~load_bits(512);
        int valid_until = in_msg_body~load_uint(32);
        int item_id = in_msg_body~load_uint(32);
        int quantity = in_msg_body~load_uint(32);
        int amount = in_msg_body~load_coins();

        (_, int user_key) = parse_std_addr(sender_address);
        (slice user_seq_no_slice, int exist) = user_seq_no_dict.udict_get?(256, user_key);

        int user_seq_no = 1;
        
        if (exist) {
            user_seq_no = user_seq_no_slice~load_uint(32);
        }

        cell cell_to_hash = begin_cell()
            .store_slice(my_address())
            .store_slice(sender_address)
            .store_uint(user_seq_no, 32)
            .store_uint(valid_until, 32)
            .store_uint(1, 32)
            .store_uint(item_id, 32)
            .store_uint(quantity, 32)
            .store_coins(amount)
            .end_cell();
        
        throw_unless(error::invalid_quantity, quantity > 0);
        throw_unless(error::deadline_expired, valid_until >= now());
        throw_unless(error::invalid_signature, check_signature(cell_hash(cell_to_hash), signature, public_key));

        user_seq_no += 1;
        slice user_seq_no_data = begin_cell().store_uint(user_seq_no, 32).end_cell().begin_parse();
        user_seq_no_dict~udict_set(256, user_key, user_seq_no_data);
        save_data();

        builder log = begin_cell()
            .store_slice(sender_address)
            .store_uint(1, 32)
            .store_uint(item_id, 32)
            .store_uint(quantity, 32)
            .store_coins(amount);
        emit_log(log::buy_item_ton, log);

        return ();
    }

    if (op == op::transfer_notification) {
        int jetton_amount = in_msg_body~load_coins();
        throw_unless(error::invalid_amount, jetton_amount > 0);

        cell ref = in_msg_body~load_ref();
        slice ref_cs = ref.begin_parse();
        cell ref2 = ref_cs~load_ref();
        slice ref_cs2 = ref2.begin_parse();
        slice signature = ref_cs2~load_bits(512);
        int valid_until = ref_cs~load_uint(32);
        int payment_type = ref_cs~load_uint(32);
        int item_id = ref_cs~load_uint(32);
        int quantity = ref_cs~load_uint(32);
        int amount = ref_cs~load_coins();
        slice buyer = ref_cs~load_msg_addr();

        (_, int user_key) = parse_std_addr(buyer);
        (slice user_seq_no_slice, int exist) = user_seq_no_dict.udict_get?(256, user_key);

        int user_seq_no = 1;
        
        if (exist) {
            user_seq_no = user_seq_no_slice~load_uint(32);
        }

        ;;check payment_type
        (slice data, int found?) = valid_jetton.udict_get?(32, payment_type);

        if (found?){
            slice jetton_wallet_address = data~load_msg_addr();
            throw_unless(error::unauthorized_address, equal_slices(sender_address, jetton_wallet_address));
        } else {
            throw(error::invalid_payment_type);
        }

        cell cell_to_hash = begin_cell()
            .store_slice(my_address())
            .store_slice(buyer)
            .store_uint(user_seq_no, 32)
            .store_uint(valid_until, 32)
            .store_uint(payment_type, 32)
            .store_uint(item_id, 32)
            .store_uint(quantity, 32)
            .store_coins(amount)
            .end_cell();

        throw_unless(error::invalid_quantity, quantity > 0);
        throw_unless(error::deadline_expired, valid_until >= now());
        throw_unless(error::invalid_signature, check_signature(cell_hash(cell_to_hash), signature, public_key));

        user_seq_no += 1;
        slice user_seq_no_data = begin_cell().store_uint(user_seq_no, 32).end_cell().begin_parse();
        user_seq_no_dict~udict_set(256, user_key, user_seq_no_data);
        save_data();

        builder log = begin_cell()
            .store_slice(sender_address)
            .store_slice(buyer)
            .store_uint(payment_type, 32)
            .store_uint(item_id, 32)
            .store_uint(quantity, 32)
            .store_coins(amount);
        emit_log(log::buy_item_jetton, log);

        return ();
    }

    if (op == op::claim_ton) { ;; claim ton
        cell ref = in_msg_body~load_ref();
        slice ref_cs = ref.begin_parse();
        slice signature = ref_cs~load_bits(512);
        int valid_until = in_msg_body~load_uint(32);
        int amount = in_msg_body~load_coins();

        (_, int user_key) = parse_std_addr(sender_address);
        (slice user_seq_no_slice, int exist) = user_seq_no_dict.udict_get?(256, user_key);

        int user_seq_no = 1;
        
        if (exist) {
            user_seq_no = user_seq_no_slice~load_uint(32);
        }

        cell cell_to_hash = begin_cell()
            .store_slice(my_address())
            .store_slice(sender_address)
            .store_uint(user_seq_no, 32)
            .store_uint(valid_until, 32)
            .store_uint(1001, 32)
            .store_coins(amount)
            .end_cell();

        throw_unless(error::deadline_expired, valid_until >= now());
        throw_unless(error::invalid_signature, check_signature(cell_hash(cell_to_hash), signature, public_key));

        user_seq_no += 1;
        slice user_seq_no_data = begin_cell().store_uint(user_seq_no, 32).end_cell().begin_parse();
        user_seq_no_dict~udict_set(256, user_key, user_seq_no_data);
        save_data();

        var msg = begin_cell()
            .store_uint(0x18, 6) ;; Message mode (0x18 = simple send)
            .store_slice(sender_address)  
            .store_coins(amount) 
            .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1) 
            .end_cell();
        send_raw_message(msg, 64); 

        builder log = begin_cell()
            .store_slice(sender_address)
            .store_uint(1001, 32)
            .store_coins(amount);
        emit_log(log::claim_ton, log);

        return ();
    }

    if (op == op::claim_jetton) { ;; claim jetton
        cell ref = in_msg_body~load_ref();
        slice ref_cs = ref.begin_parse();
        slice signature = ref_cs~load_bits(512);
        int valid_until = in_msg_body~load_uint(32);
        int amount = in_msg_body~load_coins();
        int forward_ton_amount = in_msg_body~load_coins();
        cell either_forward_payload = in_msg_body~load_maybe_ref();
        slice jetton_wallet_address = in_msg_body~load_msg_addr();

        (_, int user_key) = parse_std_addr(sender_address);
        (slice user_seq_no_slice, int exist) = user_seq_no_dict.udict_get?(256, user_key);

        int user_seq_no = 1;
        
        if (exist) {
            user_seq_no = user_seq_no_slice~load_uint(32);
        }

        cell cell_to_hash = begin_cell()
            .store_slice(my_address())
            .store_slice(sender_address)
            .store_uint(user_seq_no, 32)
            .store_uint(valid_until, 32)
            .store_uint(1002, 32)
            .store_coins(amount)
            .store_slice(jetton_wallet_address)
            .end_cell();

        throw_unless(error::deadline_expired, valid_until >= now());
        throw_unless(error::invalid_signature, check_signature(cell_hash(cell_to_hash), signature, public_key));

        user_seq_no += 1;
        slice user_seq_no_data = begin_cell().store_uint(user_seq_no, 32).end_cell().begin_parse();
        user_seq_no_dict~udict_set(256, user_key, user_seq_no_data);
        save_data();

        var transfer_msg = begin_cell()
            .store_uint(op::transfer, 32)
            .store_uint(query_id, 64)
            .store_coins(amount)
            .store_slice(sender_address)
            .store_slice(sender_address)
            .store_uint(0, 1) ;; store_dict(null())
            .store_coins(forward_ton_amount)
            .store_maybe_ref(either_forward_payload)
            .end_cell();

        var msg = begin_cell()
            .store_msg_flags_and_address_none(BOUNCEABLE)
            .store_slice(jetton_wallet_address)
            .store_coins(0)
            .store_only_body_ref(transfer_msg);
        send_raw_message(msg.end_cell(), SEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE);
       
        builder log = begin_cell()
            .store_slice(sender_address)
            .store_uint(1002, 32)
            .store_coins(amount);
        emit_log(log::claim_jetton, log);

        return ();
    }

    if (op == op::withdraw_ton) { ;; withdraw ton
        throw_unless(error::unauthorized_address, equal_slices(sender_address, owner_address));

        int MIN_TON_FOR_STORAGE = 50000000; 

        in_msg_body.end_parse();
        throw_unless(92, my_balance > MIN_TON_FOR_STORAGE);
        raw_reserve(MIN_TON_FOR_STORAGE, RESERVE_REGULAR);

        cell msg = begin_cell()
            .store_msg_flags_and_address_none(NON_BOUNCEABLE)
            .store_slice(owner_address)
            .store_coins(0)
            .store_prefix_only_body()
            .store_uint(op::top_up, 32)
            .store_uint(query_id, 64)
            .end_cell();
        send_raw_message(msg, SEND_MODE_CARRY_ALL_BALANCE);
        return ();
    }

    if (op == op::withdraw_jetton) { ;; withdraw jetton
        throw_unless(error::unauthorized_address, equal_slices(sender_address, owner_address));
        int available_amount = in_msg_body~load_coins();
        int forward_ton_amount = in_msg_body~load_coins();
        cell either_forward_payload = in_msg_body~load_maybe_ref();
        slice jetton_wallet_address = in_msg_body~load_msg_addr();
        slice receiver_address = in_msg_body~load_msg_addr();

        var transfer_msg = begin_cell()
            .store_uint(op::transfer, 32)
            .store_uint(query_id, 64)
            .store_coins(available_amount)
            .store_slice(receiver_address)
            .store_slice(receiver_address)
            .store_uint(0, 1) ;; store_dict(null())
            .store_coins(forward_ton_amount)
            .store_maybe_ref(either_forward_payload)
            .end_cell();

        var msg = begin_cell()
            .store_msg_flags_and_address_none(BOUNCEABLE)
            .store_slice(jetton_wallet_address)
            .store_coins(0)
            .store_only_body_ref(transfer_msg);
        send_raw_message(msg.end_cell(), SEND_MODE_CARRY_ALL_REMAINING_MESSAGE_VALUE);

        return ();
    }

    if (op == op::update_public_key) { ;; update public_key
      throw_unless(error::unauthorized_address, equal_slices(sender_address, owner_address));
      public_key = in_msg_body~load_uint(256);
      save_data();
      return ();
    }

    if (op == op::set_valid_jetton) { 
        throw_unless(error::unauthorized_address, equal_slices(sender_address, owner_address));
        int payment_type = in_msg_body~load_uint(32);
        slice jetton_wallet_address = in_msg_body~load_msg_addr();

        cell message = begin_cell().store_slice(jetton_wallet_address).end_cell();
        valid_jetton~udict_set(32, payment_type, message.begin_parse());

        save_data();
        return ();
    }

    throw(0xffff); ;; if the message contains an op that is not known to this contract, we throw
}

;; get methods are a means to conveniently read contract data using, for example, HTTP APIs
;; they are marked with method_id
;; note that unlike in many other smart contract VMs, get methods cannot be called by other contracts

int get_id() method_id {
    load_data();
    return ctx_id;
}

slice get_valid_jetton(int payment_type) method_id {
    load_data();
    (slice data, int found?) = valid_jetton.udict_get?(32, payment_type);

    if (found?){
        return data~load_msg_addr();
    } else {
        return "";
    }
}

(int) get_user_seq_no(slice address) method_id {
    load_data();

    (_, int user_key) = parse_std_addr(address);
    (slice user_seq_no_slice, int exist) = user_seq_no_dict.udict_get?(256, user_key);
    int user_seq_no = 1;

    if (exist) {
        user_seq_no = user_seq_no_slice~load_uint(32);
    }

    return (user_seq_no);
}







