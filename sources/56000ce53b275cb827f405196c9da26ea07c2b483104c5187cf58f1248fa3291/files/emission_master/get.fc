(int, int, int, slice, slice, cell) get_emission_master_data() method_id {
    load_storage();
    return (
        storage::price_magix_usd,
        storage::price_ton_usd,
        storage::comission_ton,
        storage::admin,
        storage::jetton_wallet_address,
        storage::emission_wallet_code
    );
}
