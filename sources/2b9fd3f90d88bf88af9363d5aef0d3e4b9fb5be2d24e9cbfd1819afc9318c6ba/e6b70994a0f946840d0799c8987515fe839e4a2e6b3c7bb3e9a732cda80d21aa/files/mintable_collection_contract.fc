;; NFT collection smart contract

;; storage scheme
;; default#_ royalty_factor:uint16 royalty_base:uint16 royalty_address:MsgAddress = RoyaltyParams;
;; storage#_ owner_address:MsgAddress next_item_index:uint64
;;           ^[collection_content:^Cell common_content:^Cell]
;;           nft_item_code:^Cell
;;           royalty_params:^RoyaltyParams
;;           = Storage;

#include "imports/stdlib.fc";
#include "op-codes.fc";
#include "imports/params.fc";

(slice, int, int, cell, cell, cell, cell) load_data() inline {
  var ds = get_data().begin_parse();
  return
    (ds~load_msg_addr(), ;; owner_address
     ds~load_uint(64), ;; next_item_index
     ds~load_uint(64), ;; max_supply
     ds~load_ref(),  ;; content
     ds~load_ref(),  ;; nft_item_code
     ds~load_ref(),  ;; royalty_params
     ds~load_dict() ;; tier_params
    );
}

() save_data(
  slice owner_address,
  int next_item_index,
  int max_supply,
  cell content,
  cell nft_item_code,
  cell royalty_params,
  cell tier_params
) impure inline {
  set_data(begin_cell()
    .store_slice(owner_address)
    .store_uint(next_item_index, 64)
    .store_uint(max_supply, 64)
    .store_ref(content)
    .store_ref(nft_item_code)
    .store_ref(royalty_params)
    .store_dict(tier_params)
    .end_cell());
}

cell calculate_nft_item_state_init(int item_index, cell nft_item_code) {
  cell data = begin_cell().store_uint(item_index, 64).store_slice(my_address()).end_cell();
  return begin_cell().store_uint(0, 2).store_dict(nft_item_code).store_dict(data).store_uint(0, 1).end_cell();
}

slice calculate_nft_item_address(int wc, cell state_init) {
  return begin_cell().store_uint(4, 3)
                     .store_int(wc, 8)
                     .store_uint(cell_hash(state_init), 256)
                     .end_cell()
                     .begin_parse();
}

() deploy_nft_item(int item_index, cell nft_item_code, int amount, cell nft_content) impure {
  cell state_init = calculate_nft_item_state_init(item_index, nft_item_code);
  slice nft_address = calculate_nft_item_address(workchain(), state_init);
  var msg = begin_cell()
            .store_uint(0x18, 6)
            .store_slice(nft_address)
            .store_coins(amount)
            .store_uint(4 + 2 + 1, 1 + 4 + 4 + 64 + 32 + 1 + 1 + 1)
            .store_ref(state_init)
            .store_ref(nft_content);
  send_raw_message(msg.end_cell(), 1); ;; pay transfer fees separately, revert on errors
}

;; Добавление тира
() add_new_tier(int tier_index, int tier_price, int tier_supply, cell tier_content) impure {
    var (owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params) = load_data();
    
    ;; Создание новой ячейки для тира с флагом паузы
    cell new_tier = begin_cell()
        .store_coins(tier_price)
        .store_uint(tier_supply, 64)
        .store_uint(0, 64) ;; Изначально следующий индекс равен 0
        .store_uint(0, 1) ;; Флаг паузы (0 - не на паузе, 1 - на паузе)
        .store_ref(tier_content)
        .end_cell();
    
    ;; Добавление нового тира в словарь
    tier_params~udict_set_ref(64, tier_index, new_tier);
    
    ;; Сохранение обновленных данных
    save_data(owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params);
}

() pause_tier(int tier_index) impure {
    var (owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params) = load_data();
    (cell tier, int success?) = tier_params.udict_get_ref?(64, tier_index);
    throw_unless(404, success?);

    slice ts = tier.begin_parse();
    int tier_price = ts~load_coins();
    int tier_supply = ts~load_uint(64);
    int tier_next_index = ts~load_uint(64);
    int pause_flag = ts~load_uint(1);
    cell tier_content = ts~load_ref();
    
    ;; Устанавливаем флаг паузы
    pause_flag = 1;

    cell updated_tier = begin_cell()
        .store_coins(tier_price)
        .store_uint(tier_supply, 64)
        .store_uint(tier_next_index, 64)
        .store_uint(pause_flag, 1)
        .store_ref(tier_content)
        .end_cell();

    tier_params~udict_set_ref(64, tier_index, updated_tier);
    save_data(owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params);
}

() resume_tier(int tier_index) impure {
    var (owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params) = load_data();
    (cell tier, int success?) = tier_params.udict_get_ref?(64, tier_index);
    throw_unless(404, success?);

    slice ts = tier.begin_parse();
    int tier_price = ts~load_coins();
    int tier_supply = ts~load_uint(64);
    int tier_next_index = ts~load_uint(64);
    int pause_flag = ts~load_uint(1);
    cell tier_content = ts~load_ref();
    
    ;; Снимаем флаг паузы
    pause_flag = 0;

    cell updated_tier = begin_cell()
        .store_coins(tier_price)
        .store_uint(tier_supply, 64)
        .store_uint(tier_next_index, 64)
        .store_uint(pause_flag, 1)
        .store_ref(tier_content)
        .end_cell();

    tier_params~udict_set_ref(64, tier_index, updated_tier);
    save_data(owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params);
}

() send_royalty_params(slice to_address, int query_id, slice data) impure inline {
  var msg = begin_cell()
    .store_uint(0x10, 6) ;; nobounce - int_msg_info$0 ihr_disabled:Bool bounce:Bool bounced:Bool packages:MsgAddress -> 011000
    .store_slice(to_address)
    .store_coins(0)
    .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1)
    .store_uint(op::report_royalty_params(), 32)
    .store_uint(query_id, 64)
    .store_slice(data);
  send_raw_message(msg.end_cell(), 64); ;; carry all the remaining value of the inbound message
}

() recv_internal(int my_balance, int msg_value, cell in_msg_full, slice in_msg_body) impure {
    if (in_msg_body.slice_empty?()) { ;; ignore empty messages
        return ();
    }
    slice cs = in_msg_full.begin_parse();
    int flags = cs~load_uint(4);

    if (flags & 1) { ;; ignore all bounced messages
        return ();
    }
    slice sender_address = cs~load_msg_addr();

    int op = in_msg_body~load_uint(32);
    int query_id = in_msg_body~load_uint(64);

    var (
      owner_address,
      next_item_index,
      max_supply,
      content,
      nft_item_code,
      royalty_params,
      tier_params) = load_data();

    if (op == op::get_royalty_params()) {
        send_royalty_params(sender_address, query_id, royalty_params.begin_parse());
        return ();
    }

    if (op == 1) { ;; deploy new nft
      int tier_index = in_msg_body~load_uint(64);
      (cell tier, int success?) = tier_params.udict_get_ref?(64, tier_index);
      throw_unless(404, success?);

      slice ts = tier.begin_parse();
      int tier_price = ts~load_coins();
      int tier_supply = ts~load_uint(64);
      int tier_next_index = ts~load_uint(64);
      cell tier_content = ts~load_ref();
      throw_unless(403, tier_next_index <= tier_supply);
      throw_unless(403, tier_price <= (msg_value - min_tons_for_storage()));

      deploy_nft_item(
        next_item_index,
        nft_item_code,
        in_msg_body~load_coins(),
        begin_cell()
          .store_slice(sender_address)
          .store_ref(tier_content)
          .end_cell()
      );
      tier_next_index += 1;
      next_item_index += 1;

      cell updated_tier = begin_cell()
        .store_coins(tier_price)
        .store_uint(tier_supply, 64)
        .store_uint(tier_next_index, 64)
        .store_ref(tier_content)
        .end_cell();

      tier_params~udict_set_ref(64, tier_index, updated_tier);

      save_data(owner_address, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params);
      return ();
    }

    throw_unless(401, equal_slices(sender_address, owner_address));

    if (op == 2) { ;; add new tier
        int tier_index = in_msg_body~load_uint(64);
        int tier_price = in_msg_body~load_coins();
        int tier_supply = in_msg_body~load_uint(64);
        cell tier_content = in_msg_body~load_ref();
        add_new_tier(tier_index, tier_price, tier_supply, tier_content);
        return ();
    }

    if (op == 3) { ;; change owner
      slice new_owner = in_msg_body~load_msg_addr();
      save_data(new_owner, next_item_index, max_supply, content, nft_item_code, royalty_params, tier_params);
      return ();
    }
    if (op == 4) { ;; change content
      save_data(owner_address, next_item_index, max_supply, in_msg_body~load_ref(), nft_item_code, in_msg_body~load_ref(), tier_params);
      return ();
    }
    if (op == 4) { ;; change content
      save_data(owner_address, next_item_index, max_supply, in_msg_body~load_ref(), nft_item_code, in_msg_body~load_ref(), tier_params);
      return ();
    }

    if (op == 5) { ;; pause tier
        int tier_index = in_msg_body~load_uint(64);
        pause_tier(tier_index);
        return ();
    }

    if (op == 6) { ;; resume tier
        int tier_index = in_msg_body~load_uint(64);
        resume_tier(tier_index);
        return ();
    }
    if (op == op::take_balance()) {
        slice address = in_msg_body~load_msg_addr();
        var msg = begin_cell()
          .store_uint(0x10, 6) ;; nobounce - int_msg_info$0 ihr_disabled:Bool bounce:Bool bounced:Bool packages:MsgAddress -> 011000
          .store_slice(address)
          .store_coins(my_balance - min_tons_for_storage())
          .store_uint(0, 1 + 4 + 4 + 64 + 32 + 1 + 1);
        send_raw_message(msg.end_cell(), 0); 
      return ();
    }
    throw(0xffff);
}

;; Get methods

(int, cell, slice) get_collection_data() method_id {
  var (owner_address, next_item_index, _, content, _, _, _) = load_data();
  slice cs = content.begin_parse();
  return (next_item_index, cs~load_ref(), owner_address);
}

(int, int, int) get_tier_data(int tier_index) method_id {
  var (_, _, _, _, _, _, tier_params) = load_data();
  (cell tier, int success?) = tier_params.udict_get_ref?(64, tier_index);
  throw_unless(404, success?);
  slice ts = tier.begin_parse();
  return (ts~load_coins(), ts~load_uint(64), ts~load_uint(64));
}

(cell) get_tiers_data() method_id {
  var (_, _, _, _, _, _, tier_params) = load_data();
  return tier_params;
}

slice get_nft_address_by_index(int index) method_id {
    var (_, _, _, _, nft_item_code, _, _) = load_data();
    cell state_init = calculate_nft_item_state_init(index, nft_item_code);
    return calculate_nft_item_address(0, state_init);
}

(int, int, slice) royalty_params() method_id {
     var (_, _, _, _, _, royalty, _) = load_data();
     slice rs = royalty.begin_parse();
     return (rs~load_uint(16), rs~load_uint(16), rs~load_msg_addr());
}

cell get_nft_content(int index, cell individual_nft_content) method_id {
  var (_, _, _, content, _, _, _) = load_data();
  slice cs = content.begin_parse();
  cs~load_ref();
  slice common_content = cs~load_ref().begin_parse();
  return (begin_cell()
                      .store_uint(1, 8) ;; offchain tag
                      .store_slice(common_content)
                      .store_ref(individual_nft_content)
          .end_cell());
}
